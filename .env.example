# SAROS_TOKEN=
# SAROS_ADMIN_USERS=

# The web origin. Its host doubles as the passkey rp-id and the session-cookie
# Domain; https implies Secure cookies.
# SAROS_RP_ORIGIN=http://localhost:5173

# Setting these activates the S3/Tigris egress mirror (unset = serve from disk).
# SAROS_S3_ENDPOINT=
# SAROS_S3_BUCKET=
# SAROS_S3_REGION=auto
# SAROS_S3_ACCESS_KEY_ID=
# SAROS_S3_SECRET_ACCESS_KEY=
# SAROS_BLOB_PUBLIC_BASE=
